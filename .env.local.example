# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional, for production rate-limiting (20 generations / IP / day).
# On Vercel, adding the Upstash marketplace integration auto-populates these.
# If missing, the API falls back to an in-memory Map (per-server, per-restart).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
